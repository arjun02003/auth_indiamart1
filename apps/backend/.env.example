# ═══════════════════════════════════════════
# ASN Expo AI Sales Agent — Environment Variables
# ═══════════════════════════════════════════
# Copy this file to .env and fill in the values

# ─── Server ───────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Database (PostgreSQL) ────────────────
# Local: postgresql://user:password@localhost:5432/asnexpo_db
# Neon: postgresql://user:password@ep-xxx.neon.tech/asnexpo_db?sslmode=require
DATABASE_URL=postgresql://postgres:password@localhost:5432/asnexpo_db

# ─── JWT ──────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-change-this
JWT_EXPIRES_IN=7d

# ─── Google Gemini AI ─────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ─── Email (SMTP) ─────────────────────────
# For Gmail: enable 2FA and create App Password
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=asnexpo94@gmail.com
SMTP_PASS=your-gmail-app-password-here

# ─── Frontend URL (for CORS) ──────────────
FRONTEND_URL=http://localhost:3000

# ─── Cloudinary (File/Image Storage) ──────
# Get from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─── WhatsApp Business API (Optional) ─────
WHATSAPP_API_TOKEN=your-whatsapp-token
WHATSAPP_PHONE_ID=your-phone-number-id
WHATSAPP_WEBHOOK_SECRET=your-webhook-secret

# ─── Logging ──────────────────────────────
LOG_LEVEL=info
